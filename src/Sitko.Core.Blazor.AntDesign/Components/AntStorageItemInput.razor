@inherits BaseAntStorageFileInputComponent<Sitko.Core.Storage.StorageItem>
@using Microsoft.AspNetCore.Components.Forms
<div class="ant-upload ant-upload-select ant-upload-select-@(ListType)">
    <span tabindex="0" class="ant-upload" role="button">
        <InputFile id="@InputId" @key="InputFileKey" style="display: none;" OnChange="@UploadFilesAsync"
                   accept="@ContentTypes"/>
        @if (ChildContent is null)
        {
            <div class="ant-upload ant-upload-select">
                <span class="ant-upload">
                    <label for="@InputId">
                    <AntDesign.Button Disabled="IsLoading" Loading="IsLoading"
                                      Icon="@(IsLoading ? "Loading" : "upload")">
                        <span>@ButtonText</span>
                    </AntDesign.Button>
                    </label>
                </span>
            </div>
        }
        else
        {
            <label for="@InputId">
                @ChildContent
            </label>
        }
    </span>
</div>
